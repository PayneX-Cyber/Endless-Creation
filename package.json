{
  "scripts": {
    "check": "npm run build",
    "test:ai-workflow": "node --test --test-concurrency=8 tools/ai-workflow/test/*.test.mjs",
    "check:ai-workflow": "npm run test:ai-workflow && npm run build",
    "dev": "vite",
    "dev:electron": "concurrently -k -n renderer,electron \"vite --host 127.0.0.1 --port 5174 --strictPort\" \"wait-on tcp:5174 && npm run build:electron && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5174 electron .\"",
    "build:renderer": "tsc -b && vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "npm run build:renderer && npm run build:electron",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fission-ai/openspec": "^1.6.0",
    "@vitejs/plugin-react": "^6.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "vite": "^8.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.5.0",
    "tailwindcss": "^4.3.1",
    "wait-on": "^9.0.10"
  },
  "main": "dist-electron/main/index.js"
}
